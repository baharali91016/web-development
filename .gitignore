# ============================================================
# Node.js dependencies
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================================
# Environment variables & secrets — NEVER commit these
# ============================================================
.env
.env.local
.env.development
.env.test
.env.production
*.pem
*.key

# ============================================================
# Logs & runtime data
# ============================================================
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# ============================================================
# Editor & IDE folders
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ============================================================
# Operating system junk files
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ============================================================
# Build artifacts & caches
# ============================================================
dist/
build/
coverage/
.nyc_output/
.cache/
.parcel-cache/

# ============================================================
# Optional: package-lock.json
# ============================================================
# Keep package-lock.json in Git — it locks dependency versions
# for reproducible installs. Only ignore it if your team uses yarn.lock
# or pnpm-lock.yaml instead.
# package-lock.json